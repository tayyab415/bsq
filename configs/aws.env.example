# Copy to repo root as aws-hackathon.env (gitignored) or export in shell.
# See ISB-UserGuide.pdf for account setup.

export AWS_PROFILE=hackathon
export AWS_DEFAULT_PROFILE=hackathon
export AWS_REGION=eu-central-1
export AWS_DEFAULT_REGION=eu-central-1
export AWS_SDK_LOAD_CONFIG=1
export AWS_ACCOUNT_ID=652386518002
export HACKATHON_BUCKET=hackathon-data-652386518002
export HACKATHON_CHALLENGE="Challenge 2 – Unlock the Power of 3D Football Data"

